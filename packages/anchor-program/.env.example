# Path to the deployer keypair (must hold SOL on the target cluster)
ANCHOR_WALLET=~/.config/solana/id.json

# `devnet` (default) | `localnet` | `mainnet-beta`
ANCHOR_PROVIDER=devnet

# Chainlink CCIP Solana router program id for `dispatch_reputation_to_tempo`.
# Devnet: Ccip... (publish address from https://docs.chain.link/ccip/directory)
# Mainnet: Ccip...
CHAINLINK_CCIP_PROGRAM_ID=
