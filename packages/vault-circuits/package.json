{
  "name": "@stargazempp/vault-circuits",
  "version": "0.0.0",
  "private": true,
  "description": "Groth16 circuits + on-chain verifiers for StargazeVault privacy tiers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "circuits"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "compile:aggregate": "circom circuits/aggregate_sum.circom --r1cs --wasm --sym -l node_modules -l ../../node_modules -o build/",
    "setup:aggregate-dev": "node scripts/setup-dev.mjs aggregate_sum",
    "all:aggregate-dev": "npm run compile:aggregate && npm run setup:aggregate-dev",
    "compile:geofence": "circom circuits/geofence.circom --r1cs --wasm --sym -l node_modules -l ../../node_modules -o build/",
    "setup:geofence-dev": "node scripts/setup-dev.mjs geofence",
    "all:geofence-dev": "npm run compile:geofence && npm run setup:geofence-dev",
    "compile:mean": "circom circuits/aggregate_mean.circom --r1cs --wasm --sym -l node_modules -l ../../node_modules -o build/",
    "setup:mean-dev": "node scripts/setup-dev.mjs aggregate_mean",
    "all:mean-dev": "npm run compile:mean && npm run setup:mean-dev",
    "prove:aggregate-sum": "node scripts/emit-rust-vkey.mjs --circuit aggregate_sum",
    "prove:geofence": "node scripts/emit-rust-vkey.mjs --circuit geofence"
  },
  "dependencies": {
    "@stargazempp/shared": "*",
    "circomlib": "^2.0.5",
    "snarkjs": "^0.7.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  }
}
